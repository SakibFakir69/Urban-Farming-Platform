// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`
// READ MODEL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum CertStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            Int             @id @default(autoincrement())
  name          String
  email         String          @unique
  password      String
  role          Role            @default(CUSTOMER)
  status        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  post          CommunityPost[]
  orders        Order[]
  vendorProfile VendorProfile?
}

model VendorProfile {
  id                  Int     @id @default(autoincrement())
  userId              Int     @unique
  farmName            String  @unique
  certificationStatus Boolean @default(false)
  farmLocation        String

  sustainabilityCert SustainabilityCert?
  user               User                @relation(fields: [userId], references: [id])
  rentalSpaces       RentalSpace[]
  produces           Produce[]
  orders             Order[]
}

model SustainabilityCert {
  id                Int           @id @default(autoincrement())
  vendorId          Int           @unique
  certifyingAgency  String
  certificationDate DateTime
  status            CertStatus    @default(PENDING)
  vendor            VendorProfile @relation(fields: [vendorId], references: [userId])
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  postContent String
  postDate    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model RentalSpace {
  id           Int           @id @default(autoincrement())
  vendorId     Int
  location     String
  size         String
  price        Int
  availability Boolean       @default(true)
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
}

model Produce {
  id                  Int           @id @default(autoincrement())
  vendorId            Int
  name                String
  description         String
  price               Int
  category            String
  certificationStatus Boolean       @default(false)
  availableQuantity   Int
  vendor              VendorProfile @relation(fields: [vendorId], references: [id])
  orders              Order[]
}

// how gave order
model Order {
  id        Int           @id @default(autoincrement())
  userId    Int
  produceId Int
  vendorId  Int
  status    String        @default("PENDING")
  orderDate DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  produce   Produce       @relation(fields: [produceId], references: [id])
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
}
